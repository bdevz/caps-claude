# Consultadd RFP Skills Pack — environment schema.
# Copy this to .env and fill in real values. .env is gitignored; this file is not.
# NEVER commit real secrets — only the schema lives in .env.example.

# === Reducto (PDF parsing) ===
REDUCTO_API_KEY=<paste-your-reducto-api-key-here>
REDUCTO_BASE_URL=https://platform.reducto.ai

# === Telemetry (per-analyst usage tracking) ===
# Ask your team lead. Leaving blank is fine while testing — skills no-op telemetry then.
CONSULTADD_TEL_ENDPOINT=
CONSULTADD_TEL_KEY=
CONSULTADD_ANALYST_ID=<your-name>

# === Cross-verify (optional Codex CLI second voice) ===
CONSULTADD_USE_CODEX=false

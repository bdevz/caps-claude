#!/bin/bash
# Install Consultadd RFP skills pack into ~/.claude/skills/
# Symlinks each skill folder so edits in this repo are immediately live.
set -e

REPO_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
TARGET_DIR="$HOME/.claude/skills"
mkdir -p "$TARGET_DIR"

SKILLS=(
  parse-rfp
  firm-background
  eligibility-check
  tech-expert
  legal-expert
  ops-expert
  sales-mktg-expert
  public-policy-expert
  writer
  reviewer
  cross-verify
  rfp
)

linked=0
skipped=0
for skill in "${SKILLS[@]}"; do
  if [[ -d "$REPO_DIR/$skill" ]]; then
    ln -snf "$REPO_DIR/$skill" "$TARGET_DIR/$skill"
    echo "  linked $skill"
    linked=$((linked+1))
  else
    skipped=$((skipped+1))
  fi
done

echo ""
echo "Installed $linked skills to $TARGET_DIR ($skipped not yet built)"
echo ""
echo "Set telemetry env vars in your shell profile:"
echo "  export CONSULTADD_TEL_ENDPOINT=https://<project>.supabase.co/functions/v1/ingest"
echo "  export CONSULTADD_TEL_KEY=<service token>"
echo "  export CONSULTADD_ANALYST_ID=\"\$USER\""
echo ""
echo "Restart Claude Code to pick up new skills."

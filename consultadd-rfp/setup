#!/bin/bash
# Install Consultadd RFP skills pack into ~/.claude/skills/
# Symlinks each skill folder so edits in this repo are immediately live.
set -e

REPO_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
TARGET_DIR="$HOME/.claude/skills"
mkdir -p "$TARGET_DIR"

# --- Bootstrap .env from .env.example if missing -------------------
if [[ ! -f "$REPO_DIR/.env" ]]; then
  if [[ -f "$REPO_DIR/.env.example" ]]; then
    cp "$REPO_DIR/.env.example" "$REPO_DIR/.env"
    echo "Created $REPO_DIR/.env from .env.example."
    echo "  Edit it to set REDUCTO_API_KEY and CONSULTADD_ANALYST_ID before first use."
    echo ""
  fi
fi

# --- Symlink the skills pack root so load-env.sh finds .env --------
ln -snf "$REPO_DIR" "$TARGET_DIR/consultadd-rfp"
echo "  linked consultadd-rfp/ (pack root, includes .env + lib/)"

# --- Symlink each individual skill folder --------------------------
SKILLS=(
  parse-rfp
  firm-background
  eligibility-check
  tech-expert
  legal-expert
  ops-expert
  sales-mktg-expert
  public-policy-expert
  writer
  reviewer
  cross-verify
  rfp
)

linked=0
skipped=0
for skill in "${SKILLS[@]}"; do
  if [[ -d "$REPO_DIR/$skill" ]]; then
    ln -snf "$REPO_DIR/$skill" "$TARGET_DIR/$skill"
    echo "  linked $skill"
    linked=$((linked+1))
  else
    skipped=$((skipped+1))
  fi
done

echo ""
echo "Installed $linked skills to $TARGET_DIR ($skipped not yet built)"
echo ""
echo "Next steps:"
echo "  1. Edit $REPO_DIR/.env to add your REDUCTO_API_KEY and CONSULTADD_ANALYST_ID."
echo "  2. Restart Claude Code to pick up the new skills."
echo "  3. Try /parse-rfp <path/to/some.pdf> to verify the pipeline works end-to-end."

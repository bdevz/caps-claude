# Reducto MCP server — environment schema.
# Copy to .env locally for development; set via `fly secrets set` in production.

# === Reducto API ===
REDUCTO_API_KEY=<paste-your-reducto-api-key-here>
REDUCTO_BASE_URL=https://platform.reducto.ai

# === MCP server runtime ===
PORT=8080

# === Optional security ===
# Comma-separated list of IPs allowed to call this server, for v1.5's internal-use posture.
# Leave blank to allow all (HTTPS-only is still enforced by the host).
ALLOWED_IPS=
